{"id":"08-multiline","text":"First line.\nSecond line mentions Jane Smith and jane.smith+tag@example.com.","expected":[{"label":"PERSON","text":"Jane Smith"},{"label":"EMAIL","text":"jane.smith+tag@example.com"}]}
{"id":"09-phone_parens","text":"Support: (555) 123-4567 or +44 20 7946 0958.","expected":[{"label":"PHONE","text":"(555) 123-4567"},{"label":"PHONE","text":"+44 20 7946 0958"}]}
